{
  "openapi": "3.0.0",
  "info": {
    "title": "BioStar Mock API",
    "version": "1.0.0",
    "description": "Mock API to simulate BioStar 2 access control events."
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "BioStar Mock Server"
    }
  ],
  "paths": {
    "/api/events": {
      "post": {
        "summary": "Simulate an access event",
        "description": "Generates a new access event for a specific user and device.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": {
                    "type": "string",
                    "description": "The BioStar ID of the person."
                  },
                  "device_id": {
                    "type": "string",
                    "description": "The BioStar ID of the access point (device)."
                  },
                  "type": {
                    "type": "string",
                    "description": "Type of event, e.g., 'ENTRADA' or 'SALIDA'."
                  },
                  "datetime": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Optional timestamp of the event."
                  }
                },
                "required": ["user_id", "device_id", "type"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Event created successfully"
          },
          "400": {
            "description": "Missing required fields"
          }
        }
      },
      "get": {
        "summary": "Get all generated events",
        "description": "Returns all access events generated by the mock (useful for debugging).",
        "responses": {
          "200": {
            "description": "A list of all events"
          }
        }
      }
    },
    "/api/events/search": {
      "get": {
        "summary": "Search events by date range",
        "description": "Simulates the BioStar search endpoint to fetch events within a specific datetime range.",
        "parameters": [
          {
            "in": "query",
            "name": "start_datetime",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Start datetime filter"
          },
          {
            "in": "query",
            "name": "end_datetime",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "End datetime filter"
          }
        ],
        "responses": {
          "200": {
            "description": "List of events matching the filter"
          }
        }
      }
    }
  }
}
